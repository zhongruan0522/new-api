# ============================================================
# New API 环境变量配置
# 使用方法：复制本文件为 .env，然后根据需要修改配置项
# ============================================================


# ------------------------------
# 基本配置
# ------------------------------
# 服务监听端口，默认 3000
# PORT=3000
# 覆盖运行版本号，默认使用编译时内置版本
# VERSION=1.2.3
# 时区设置
# TZ=Asia/Shanghai
# Gin 运行模式，设为 release 关闭调试日志
# GIN_MODE=release
# 前端基础URL，从节点设置后所有未匹配路由将重定向到此地址
# FRONTEND_BASE_URL=https://your-frontend-url.com


# ------------------------------
# 真实客户端 IP（反向代理 / CDN）
# ------------------------------
# 逗号分隔的可信代理 IP / CIDR 列表
# 仅当请求来自可信代理时，才会解析以下请求头：
#   CF-Connecting-IP / True-Client-IP / X-Forwarded-For / X-Real-IP
#
# 特殊值：
#   private / local  : 私有 + 回环地址段（10/172.16/192.168/127.0.0.1 等）
#   cloudflare / cf  : Cloudflare 边缘 IP 段
#   all / unsafe     : 信任所有代理（不推荐，允许请求头伪造）
#   none / disable   : 不信任任何代理头（始终使用直连 RemoteAddr）
#
# 默认值（未设置时）：private,cloudflare
# TRUSTED_PROXIES=private,cloudflare
# TRUSTED_PROXIES=private,cloudflare,203.0.113.10,203.0.113.0/24


# ------------------------------
# 数据库配置
# ------------------------------
# 主数据库连接字符串，不设置则使用 SQLite
# MySQL:    SQL_DSN=user:password@tcp(127.0.0.1:3306)/dbname?parseTime=true
# PostgreSQL: SQL_DSN=postgres://user:password@127.0.0.1:5432/dbname
# SQL_DSN=
# 日志数据库连接字符串（独立存放日志），留空则与主库共用
# LOG_SQL_DSN=
# SQLite 数据库文件路径
# SQLITE_PATH=data/one-api.db
# 空闲连接池最大连接数，默认 100
# SQL_MAX_IDLE_CONNS=100
# 连接池最大打开连接数，默认 1000
# SQL_MAX_OPEN_CONNS=1000
# 连接最大生命周期（秒），默认 60
# SQL_MAX_LIFETIME=60


# ------------------------------
# 缓存配置
# ------------------------------
# Redis 连接字符串，不设置则禁用 Redis
# REDIS_CONN_STRING=redis://user:password@localhost:6379/0
# Redis 连接池大小，默认 10
# REDIS_POOL_SIZE=10
# 是否启用内存缓存，默认 false
# MEMORY_CACHE_ENABLED=true
# 缓存与数据库同步频率（秒），默认 60
# SYNC_FREQUENCY=60
# 是否启用数据库批量更新聚合，默认 false
# BATCH_UPDATE_ENABLED=true
# 批量更新聚合时间间隔（秒），默认 5
# BATCH_UPDATE_INTERVAL=5


# ------------------------------
# 多节点与安全配置
# ------------------------------
# 会话密钥，多机部署时必须设置且所有节点保持一致
# SESSION_SECRET=random_string
# 加密密钥（用于加密数据库敏感内容），不设置则使用 SESSION_SECRET
# 多机部署时必须设置且所有节点保持一致
# CRYPTO_SECRET=your_crypto_secret
# 节点类型，设为 slave 则为只读从节点（跳过迁移、根账号创建等），默认 master
# NODE_TYPE=master


# ------------------------------
# 请求限制配置
# ------------------------------
# 全局 API 速率限制开关，默认 true
# GLOBAL_API_RATE_LIMIT_ENABLE=true
# 全局 API 速率限制次数（单 IP），默认 180
# GLOBAL_API_RATE_LIMIT=180
# 全局 API 速率限制时间窗口（秒），默认 180
# GLOBAL_API_RATE_LIMIT_DURATION=180
# 全局 Web 速率限制开关，默认 true
# GLOBAL_WEB_RATE_LIMIT_ENABLE=true
# 全局 Web 速率限制次数（单 IP），默认 60
# GLOBAL_WEB_RATE_LIMIT=60
# 全局 Web 速率限制时间窗口（秒），默认 180
# GLOBAL_WEB_RATE_LIMIT_DURATION=180
# 关键操作速率限制开关，默认 true
# CRITICAL_RATE_LIMIT_ENABLE=true
# 关键操作速率限制次数，默认 20
# CRITICAL_RATE_LIMIT=20
# 关键操作速率限制时间窗口（秒），默认 1200
# CRITICAL_RATE_LIMIT_DURATION=1200
# 中继请求超时时间（秒），0 表示不限制，默认 0
# 注意：设置过短可能导致上游已计费但本地超时未完成计费
# RELAY_TIMEOUT=0
# 流式响应超时时间（秒），默认 300
# STREAMING_TIMEOUT=300
# 最大文件下载大小（MB），默认 64
# MAX_FILE_DOWNLOAD_MB=64
# 最大请求体大小（MB，解压后），防止超大请求/zip bomb 导致内存暴涨，默认 128
# MAX_REQUEST_BODY_MB=128
# SSE 流扫描器最大缓冲区（MB），默认 64
# STREAM_SCANNER_MAX_BUFFER_MB=64
# 中继 HTTP 客户端空闲连接池最大连接数，默认 500
# RELAY_MAX_IDLE_CONNS=500
# 中继 HTTP 客户端每个主机最大空闲连接数，默认 100
# RELAY_MAX_IDLE_CONNS_PER_HOST=100


# ------------------------------
# 渠道管理配置
# ------------------------------
# 定期更新渠道余额频率（分钟），不设置则不启用
# CHANNEL_UPDATE_FREQUENCY=1440
# 定期检查渠道可用性频率（分钟），不设置则不启用
# CHANNEL_TEST_FREQUENCY=1440
# 批量更新渠道时请求间隔（秒），默认 0
# POLLING_INTERVAL=0


# ------------------------------
# 模型与请求处理配置
# ------------------------------
# 是否覆盖客户端 stream_options 参数以强制返回 usage，默认 true
# FORCE_STREAM_OPTION=true
# 是否统计文本 token，默认 true
# CountToken=true
# 是否统计图片 token（流式），默认 true
# GET_MEDIA_TOKEN=true
# 是否统计图片 token（非流式），默认 false
# GET_MEDIA_TOKEN_NOT_STREAM=false
# 是否更新异步任务（MJ、Suno），默认 true
# UPDATE_TASK=true


# ------------------------------
# 特定模型配置
# ------------------------------
# Azure 渠道默认 API 版本，默认 2025-04-01-preview
# AZURE_DEFAULT_API_VERSION=2025-04-01-preview
# Cohere 模型安全设置，默认 NONE
# COHERE_SAFETY_SETTING=NONE
# Gemini 模型最大图片数量，默认 16
# GEMINI_VISION_MAX_IMAGE_NUM=16
# Dify 渠道是否输出工作流和节点信息到客户端，默认 true
# DIFY_DEBUG=true


# ------------------------------
# 用户及令牌配置
# ------------------------------
# 是否为新注册用户生成初始令牌，默认 false
# GENERATE_DEFAULT_TOKEN=false
# 通知限制的持续时间（分钟），默认 10
# NOTIFICATION_LIMIT_DURATION_MINUTE=10
# 指定持续时间内的最大通知数量，默认 2
# NOTIFY_LIMIT_COUNT=2


# ------------------------------
# 多模态资源存储配置
# 用于 text-only 模型调用 MCP 图像/视频理解工具时的自动转 URL 存储
# ------------------------------
# 单个图片大小限制（MB），0 表示不限制，默认 64
# MAX_IMAGE_UPLOAD_MB=64
# 单个视频大小限制（MB），0 表示不限制，默认 128
# MAX_VIDEO_UPLOAD_MB=128
# 图片存储池上限（MB），超过后自动删除最早的资源，默认 512
# STORED_IMAGE_POOL_MB=512
# 视频存储池上限（MB），超过后自动删除最早的资源，默认 1024
# STORED_VIDEO_POOL_MB=1024


# ------------------------------
# TLS 与网络配置
# ------------------------------
# 跳过 TLS 证书验证（适用于自签名证书），默认 false
# TLS_INSECURE_SKIP_VERIFY=false


# ------------------------------
# 可信重定向域名
# ------------------------------
# 逗号分隔的可信域名列表（支持子域名匹配），用于验证支付回调 URL 的安全性
# TRUSTED_REDIRECT_DOMAINS=example.com,myapp.io


# ------------------------------
# 元数据同步配置
# ------------------------------
# 模型/厂商元数据上游地址
# SYNC_UPSTREAM_BASE=https://basellm.github.io/llm-metadata
# 同步 HTTP 超时（秒），默认 10
# SYNC_HTTP_TIMEOUT_SECONDS=10
# 同步重试次数，默认 3
# SYNC_HTTP_RETRY=3
# 同步响应体最大大小（MB），默认 10
# SYNC_HTTP_MAX_MB=10


# ------------------------------
# 分析统计
# ------------------------------
# Umami 站点 ID，设置后注入 Umami 统计脚本
# UMAMI_WEBSITE_ID=xxxx-xxxx
# Umami 脚本地址，默认 https://analytics.umami.is/script.js
# UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js
# Google Analytics 4 站点 ID，设置后注入 GA4 统计脚本
# GOOGLE_ANALYTICS_ID=G-XXXXXXX


# ------------------------------
# 错误日志
# ------------------------------
# 是否记录并在前端显示错误日志，默认 false
# ERROR_LOG_ENABLED=false


# ------------------------------
# 调试与性能分析
# ------------------------------
# 启用 pprof 性能分析端点（端口 8005），默认 false
# ENABLE_PPROF=true
# 启用调试模式（详细日志、GORM 调试查询），默认 false
# DEBUG=true

# Pyroscope 持续性能分析配置
# PYROSCOPE_URL=http://localhost:4040
# PYROSCOPE_APP_NAME=new-api
# PYROSCOPE_BASIC_AUTH_USER=your-user
# PYROSCOPE_BASIC_AUTH_PASSWORD=your-password
# PYROSCOPE_MUTEX_RATE=5
# PYROSCOPE_BLOCK_RATE=5
# HOSTNAME=your-hostname


# ------------------------------
# LinuxDo OAuth（通常无需修改）
# ------------------------------
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user


# ------------------------------
# 前端构建时配置（在 .env 中设置供 Vite 使用）
# ------------------------------
# 前端请求后端的基础地址
# VITE_REACT_APP_SERVER_URL=https://api.example.com
